# xAI Official SDK Configuration

# xAI API Key (required — get from https://console.x.ai)
XAI_API_KEY=<your-xai-api-key>

# Redis (for background queue processing)
REDIS_URL=redis://localhost:6379/0

# Video Pipeline
DEFAULT_MODEL=grok-imagine-video
DEFAULT_RESOLUTION=480p
MAX_RETRIES=3
RETRY_BASE_DELAY=2.0
CLIP_OUTPUT_DIR=./clips
FINAL_OUTPUT_DIR=./output
MAX_CLIP_DURATION=10
LOG_LEVEL=INFO

# Dry run mode — set to true to log prompts without making API calls
DRY_RUN=false

# xAI SDK Settings
SDK_GENERATION_TIMEOUT=600
SDK_POLL_INTERVAL=1.0
