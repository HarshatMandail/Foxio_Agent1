# ─── Azure OpenAI Configuration (Required) ───────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ─── Tiered Model Deployments ─────────────────────────────────────────────────
# Full model: Used for complex multi-page analysis (3+ pages)
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# Mini model: Used for simple analysis (1-2 pages) — 97% cheaper
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-4o-mini

# ─── Cost Controls ────────────────────────────────────────────────────────────
# Max tokens per single LLM request (input + output combined)
MAX_TOKENS_PER_REQUEST=8000
# Max output tokens the LLM can generate
MAX_COMPLETION_TOKENS=2048
# Max cost allowed per agent session (in USD). Agent stops if exceeded.
MAX_COST_PER_SESSION_USD=1.0
# LLM temperature (0 = deterministic, saves tokens on retries)
LLM_TEMPERATURE=0

# ─── Caching ──────────────────────────────────────────────────────────────────
# Enable response caching (true/false). Avoids duplicate LLM calls.
ENABLE_LLM_CACHE=true
# Cache time-to-live in seconds (default: 6 hours)
CACHE_TTL_SECONDS=21600
# Cache storage directory
CACHE_DIR=cache

# ─── Budget Enforcement ───────────────────────────────────────────────────────
# Enable budget check (true/false). Blocks calls if over budget.
ENABLE_BUDGET_CHECK=true
# Cost log directory
COST_LOG_DIR=logs

# ─── Browser Configuration ────────────────────────────────────────────────────
BROWSER_USE_HEADLESS=false
BROWSER_CHANNEL=
# Set BROWSER_CHANNEL=msedge to use Microsoft Edge instead of Chromium
