# ─── Azure OpenAI Configuration (Required) ───────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ─── Tiered Model Deployments ─────────────────────────────────────────────────
# Full model: Used for complex multi-page analysis (3+ pages)
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# Mini model: Used for simple analysis (1-2 pages) — 97% cheaper
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-4o-mini

# ─── Cost Controls ────────────────────────────────────────────────────────────
MAX_TOKENS_PER_REQUEST=8000
MAX_COMPLETION_TOKENS=2048
MAX_COST_PER_SESSION_USD=1.0
LLM_TEMPERATURE=0

# ─── Caching ──────────────────────────────────────────────────────────────────
ENABLE_LLM_CACHE=true
CACHE_TTL_SECONDS=21600
CACHE_DIR=cache

# ─── Budget Enforcement ───────────────────────────────────────────────────────
ENABLE_BUDGET_CHECK=true
COST_LOG_DIR=logs

# ─── Browser Configuration ────────────────────────────────────────────────────
BROWSER_USE_HEADLESS=false
BROWSER_CHANNEL=
# Set BROWSER_CHANNEL=msedge to use Microsoft Edge instead of Chromium
BROWSER_DATA_DIR=browser_data
MAX_PAGES_TO_CRAWL=10
NAVIGATION_TIMEOUT_MS=30000
PAGE_LOAD_TIMEOUT_MS=15000
WAIT_FOR_LOGIN_TIMEOUT=300
LOGIN_CHECK_INTERVAL=3

# ─── Security ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed domains. Empty = allow all.
# Example: salesforce.com,hubspot.com,icertis.com
URL_ALLOWLIST=
# Comma-separated list of blocked domains/patterns (defaults provided)
URL_BLOCKLIST=localhost,127.0.0.1,0.0.0.0,file://,javascript:,data:,chrome://,about:
# Safe browsing mode: only crawl same-domain URLs
SAFE_BROWSING_MODE=true

# ─── Retry / Resilience ──────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0

# ─── Observability / Tracing ──────────────────────────────────────────────────
LOG_LEVEL=INFO
AUDIT_LOG_DIR=logs/audit
# LangSmith tracing (optional — set to true to enable)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=foxio-agent1
